# ─── Google Sheets (opcional) ──────────────────────────────────────────────
# Completar solo si querés leer precios desde Google Sheets en tiempo real.
# Ver instrucciones en src/app/api/repuestos/route.ts

# ID del Google Sheet (está en la URL: /spreadsheets/d/[ID]/edit)
GOOGLE_SHEETS_ID=

# JSON completo de la cuenta de servicio, sin saltos de línea
# Ejemplo: {"type":"service_account","project_id":"...","private_key":"..."}
GOOGLE_SERVICE_ACCOUNT_KEY=
